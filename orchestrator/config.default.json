{
  "_comment": "ŞABLON. İlk çalıştırmada bu dosya config.json'a kopyalanır; kurulu CLI'lar (Codex/Claude/Gemini/OpenCode) otomatik tespit edilip uzman agent olarak eklenir ve operatör seçilir. config.json kişiye özeldir ve .gitignore'dadır; bu şablonu paylaşabilirsiniz.",
  "approvalMode": "auto",
  "workingDir": "..",
  "dailyCallBudget": 150,
  "pollSeconds": 15,
  "memoryCharBudget": 8000,
  "teamContextCharBudget": 30000,
  "agentTimeoutSeconds": 900,
  "cliSilenceTimeoutSeconds": 300,
  "autonomousConsentAcceptedAt": null,
  "discoveryIgnoredAdapters": [],
  "operator": {
    "roleFile": "roles/operator.md",
    "maxRounds": 6,
    "maxDelegationsPerRound": 8,
    "maxInfrastructureRecoveryRounds": 2,
    "protocolRetries": 1,
    "passFastPath": true
  },
  "cliSettings": {
    "codex": { "model": "", "reasoningEffort": "medium", "serviceTier": "fast" },
    "opencode": { "model": "" }
  },
  "agents": {},
