    "rm -rf",
    "rm ",
    "Remove-Item",
    "del ",
    "rmdir",
    "git push",
    "git reset --hard",
    "git clean",
    "deploy",
    "DROP TABLE",
    "DELETE FROM",
    "TRUNCATE",
    "format ",
    "shutdown",
    "Stop-Computer",
    "Invoke-RestMethod",
    "Invoke-WebRequest",
    "curl -X POST",
    "curl -X PUT",
    "curl -X DELETE",
    "npm publish",
    "mail",
    "smtp"
  ]
