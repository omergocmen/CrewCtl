# -----------------------------------------------------------------------------
# Makineye özel yapılandırma ve sırlar
# -----------------------------------------------------------------------------
# config.default.json paylaşılır; gerçek config kurulu CLI yolları ve yerel ayarlar içerir.
/config.json
/config.local.json
/config.*.local.json

# Yerel ortam değişkenleri ve olası registry kimlik bilgileri.
.env
.env.*
!.env.example
!.env.*.example
.npmrc

# -----------------------------------------------------------------------------
# Orkestratör çalışma verileri
# -----------------------------------------------------------------------------
# Bu klasörler uygulama açılırken yeniden oluşturulur. Görev metinleri, agent cevapları,
# dosya yolları, promptlar, olay kayıtları ve yerel proje hafızası içerebilir.
/queue/
/state/
/memory/log.md

# Codex / agent araçlarının projeye bırakabildiği kişisel metadata.
/.agents/
/.codex/

# -----------------------------------------------------------------------------
# Bağımlılıklar, test ve derleme çıktıları
# -----------------------------------------------------------------------------
/node_modules/
/coverage/
/.nyc_output/
/dist/
/build/
/.cache/
/tmp/
/temp/

# -----------------------------------------------------------------------------
# Loglar ve geçici dosyalar
# -----------------------------------------------------------------------------
*.log
*.log.*
*.pid
*.pid.lock
*.tmp
*.temp
*.bak
*.swp
*.swo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Editör ve işletim sistemi artıkları
# -----------------------------------------------------------------------------
/.vscode/
/.idea/
*.code-workspace
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
